generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WatchlistType {
  TICKER
  POLITICIAN
}

model Trade {
  id               String   @id @default(cuid())
  source           String
  entityType       String
  direction        String
  politicianId     String?
  insiderId        String?
  issuerId         String?
  assetId          String?
  rawFilingId      String?
  externalTradeId  String?
  tradeDate        DateTime
  disclosedDate    DateTime?
  filedAt          DateTime?
  quantity         String?
  price            String?
  amountMin        String?
  amountMax        String?
  estimatedAmount  String?
  ownershipType    String?
  postTradeShares  String?
  transactionCode  String?
  assetDescription String?
  notes            String?
  isLate           Boolean  @default(false)
  isImportant      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  politician Politician? @relation(fields: [politicianId], references: [id])
  issuer     Issuer?     @relation(fields: [issuerId], references: [id])
  asset      Asset?      @relation(fields: [assetId], references: [id])

  @@index([tradeDate])
  @@index([politicianId])
  @@index([issuerId])
  @@index([assetId])
}

model Politician {
  id          String   @id @default(cuid())
  slug        String?  @unique
  fullName    String
  displayName String?
  chamber     String?
  state       String?
  party       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trades              Trade[]
  topPerformanceItems TopPerformance[]
  topActivityItems    TopActivity[]
}

model Issuer {
  id        String   @id @default(cuid())
  ticker    String?
  name      String
  sector    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]
}

model Asset {
  id        String   @id @default(cuid())
  symbol    String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]
}

model TopPerformance {
  id           String   @id @default(cuid())
  politicianId String
  score        String?
  periodLabel  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  politician Politician @relation(fields: [politicianId], references: [id])

  @@index([politicianId])
}

model TopActivity {
  id            String   @id @default(cuid())
  politicianId  String
  activityScore String?
  periodLabel   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  politician Politician @relation(fields: [politicianId], references: [id])

  @@index([politicianId])
}

model Testimonial {
  id          String   @id @default(cuid())
  quote       String?
  authorName  String?
  authorTitle String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Watchlist {
  id          String        @id @default(cuid())
  type        WatchlistType
  symbol      String?
  name        String
  note        String?
  signalLabel String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([symbol])
}
