generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Politician {
  id                  String                @id @default(cuid())
  slug                String                @unique
  fullName            String
  displayName         String?
  chamber             String?
  state               String?
  party               String?
  district            String?
  countryCode         String                @default("US")
  isActive            Boolean               @default(true)
  avatarUrl           String?
  bio                 String?
  externalRef         String?               @unique
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  ActivitySnapshot    ActivitySnapshot[]
  HoldingSnapshot     HoldingSnapshot[]
  PerformanceSnapshot PerformanceSnapshot[]
  TradeEvent          TradeEvent[]

  @@index([fullName])
  @@index([isActive])
  @@index([party])
  @@index([state])
}

model Issuer {
  id          String       @id @default(cuid())
  ticker      String       @unique
  name        String
  exchange    String?
  sector      String?
  industry    String?
  countryCode String       @default("US")
  websiteUrl  String?
  logoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Asset       Asset[]
  Insider     Insider[]
  TradeEvent  TradeEvent[]

  @@index([name])
  @@index([sector])
}

model Asset {
  id               String            @id @default(cuid())
  symbol           String            @unique
  name             String?
  instrumentType   InstrumentType
  optionType       OptionType?
  underlyingSymbol String?
  strikePrice      Decimal?          @db.Decimal(18, 4)
  expirationDate   DateTime?
  exchange         String?
  currency         String            @default("USD")
  issuerId         String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  Issuer           Issuer?           @relation(fields: [issuerId], references: [id])
  HoldingSnapshot  HoldingSnapshot[]
  TradeEvent       TradeEvent[]

  @@index([instrumentType])
  @@index([isActive])
  @@index([issuerId])
  @@index([underlyingSymbol])
}

model Testimonial {
  id           String            @id @default(cuid())
  name         String
  roleLabel    String?
  companyLabel String?
  locale       String            @default("zh-Hant")
  quote        String
  status       TestimonialStatus @default(DRAFT)
  sortOrder    Int               @default(0)
  isFeatured   Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([locale, status])
  @@index([status, sortOrder])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ActivitySnapshot {
  id            String     @id
  politicianId  String
  snapshotDate  DateTime
  windowDays    Int
  tradeCount    Int        @default(0)
  activityScore Decimal?   @db.Decimal(10, 4)
  buyCount      Int        @default(0)
  sellCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  Politician    Politician @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  @@unique([politicianId, snapshotDate, windowDays])
  @@index([activityScore])
  @@index([snapshotDate, windowDays])
  @@index([tradeCount])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FeedbackSubmission {
  id             String         @id
  name           String?
  email          String?
  telegramHandle String?
  message        String
  locale         String         @default("zh-Hant")
  status         FeedbackStatus @default(NEW)
  pagePath       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime

  @@index([email])
  @@index([status, createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model HoldingSnapshot {
  id           String          @id
  entityType   TradeEntityType
  politicianId String?
  insiderId    String?
  assetId      String
  snapshotDate DateTime
  sharesHeld   Decimal?        @db.Decimal(20, 4)
  marketValue  Decimal?        @db.Decimal(18, 2)
  sourceNote   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime
  Asset        Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  Insider      Insider?        @relation(fields: [insiderId], references: [id])
  Politician   Politician?     @relation(fields: [politicianId], references: [id])

  @@index([assetId, snapshotDate])
  @@index([entityType, snapshotDate])
  @@index([insiderId, snapshotDate])
  @@index([politicianId, snapshotDate])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Insider {
  id                String            @id
  slug              String            @unique
  fullName          String
  title             String?
  role              String?
  isDirector        Boolean           @default(false)
  isOfficer         Boolean           @default(false)
  isTenPercentOwner Boolean           @default(false)
  issuerId          String?
  externalRef       String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  HoldingSnapshot   HoldingSnapshot[]
  Issuer            Issuer?           @relation(fields: [issuerId], references: [id])
  TradeEvent        TradeEvent[]

  @@index([fullName])
  @@index([issuerId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PerformanceSnapshot {
  id           String     @id
  politicianId String
  snapshotDate DateTime
  lookbackDays Int
  avgReturn30d Decimal?   @db.Decimal(8, 4)
  avgReturn60d Decimal?   @db.Decimal(8, 4)
  winRate      Decimal?   @db.Decimal(6, 4)
  tradeCount   Int        @default(0)
  score        Decimal?   @db.Decimal(10, 4)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Politician   Politician @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  @@unique([politicianId, snapshotDate, lookbackDays])
  @@index([avgReturn30d])
  @@index([score])
  @@index([snapshotDate, lookbackDays])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model RawFiling {
  id           String       @id
  source       TradeSource
  filingId     String       @unique
  sourceUrl    String?
  filedAt      DateTime?
  acceptedAt   DateTime?
  documentType String?
  issuerName   String?
  issuerTicker String?
  reporterName String?
  rawJson      Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  TradeEvent   TradeEvent[]

  @@index([issuerTicker])
  @@index([reporterName])
  @@index([source, filedAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TradeEvent {
  id               String          @id
  source           TradeSource
  entityType       TradeEntityType
  direction        TradeDirection
  politicianId     String?
  insiderId        String?
  issuerId         String?
  assetId          String?
  rawFilingId      String?
  externalTradeId  String?         @unique
  tradeDate        DateTime
  disclosedDate    DateTime?
  filedAt          DateTime?
  quantity         Decimal?        @db.Decimal(20, 4)
  price            Decimal?        @db.Decimal(18, 4)
  amountMin        Decimal?        @db.Decimal(18, 2)
  amountMax        Decimal?        @db.Decimal(18, 2)
  estimatedAmount  Decimal?        @db.Decimal(18, 2)
  ownershipType    String?
  postTradeShares  Decimal?        @db.Decimal(20, 4)
  transactionCode  String?
  assetDescription String?
  notes            String?
  isLate           Boolean         @default(false)
  isImportant      Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  Asset            Asset?          @relation(fields: [assetId], references: [id])
  Insider          Insider?        @relation(fields: [insiderId], references: [id])
  Issuer           Issuer?         @relation(fields: [issuerId], references: [id])
  Politician       Politician?     @relation(fields: [politicianId], references: [id])
  RawFiling        RawFiling?      @relation(fields: [rawFilingId], references: [id])

  @@index([assetId, tradeDate])
  @@index([disclosedDate])
  @@index([entityType, tradeDate])
  @@index([estimatedAmount])
  @@index([filedAt])
  @@index([insiderId, tradeDate])
  @@index([isImportant, tradeDate])
  @@index([issuerId, tradeDate])
  @@index([politicianId, tradeDate])
  @@index([source, tradeDate])
  @@index([tradeDate])
}

enum FeedbackStatus {
  NEW
  REVIEWED
  ARCHIVED
}

enum InstrumentType {
  STOCK
  OPTION
  ETF
  OTHER
}

enum OptionType {
  CALL
  PUT
}

enum TestimonialStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum TradeDirection {
  BUY
  SELL
  EXERCISE
  AWARD
  OTHER
}

enum TradeEntityType {
  POLITICIAN
  INSIDER
}

enum TradeSource {
  SEC_FORM_4
  CONGRESS
  THIRD_PARTY_API
}

enum WatchlistEntityType {
  POLITICIAN
  TICKER
}

model Watchlist {
  id          String              @id @default(cuid())
  entityType  WatchlistEntityType
  symbol      String?
  label       String
  subtitle    String?
  notes       String?
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([entityType, isActive, sortOrder])
  @@index([symbol])
}
